[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = v3_req

[dn]
C = ID
ST = EastJava
L = Surabaya
O = MATAELANG
OU = CSRG
CN = mataelang-ca

[v3_req]
subjectAltName = @alt_names

[alt_names]
DNS.1 = opensearch-node1
DNS.2 = node-0.example.com
IP.1 = 127.0.0.1